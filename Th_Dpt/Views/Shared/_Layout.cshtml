<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Theology</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f4f9f6;
        }

        .modern-navbar {
            background: linear-gradient(90deg, #198754, #157347);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .main-container {
            margin-top: 100px;
            padding: 20px;
        }

        .content-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        /* Prevent modal shaking */
        .modal {
            position: fixed !important;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg modern-navbar fixed-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-bold text-white"
               asp-controller="Home"
               asp-action="Index">
                Theology
            </a>

            <button class="navbar-toggler bg-white"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end"
                 id="navbarContent">
                <ul class="navbar-nav gap-3">
                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="Home"
                           asp-action="Index">
                            Dashboard
                        </a>
                    </li>
                    @* <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="Admin"
                           asp-action="Class">
                            Class
                        </a>
                    </li> *@
                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="Admin"
                           asp-action="Evangelism">
                            Evangelism
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="User"
                           asp-action="Create">
                            Users
                        </a>
                    </li>
                    @* <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="Report"
                           asp-action="ClassReport">
                            Report
                        </a>
                    </li> *@
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-white"
                           href="#"
                           id="reportDropdown"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">
                            Report
                        </a>
                        <ul class="dropdown-menu"
                            aria-labelledby="reportDropdown">
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Report"
                                   asp-action="ClassReport">
                                    Class Report
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Report"
                                   asp-action="GenerateReport">
                                    Generate Report
                                </a>
                            </li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="Home"
                           asp-action="Logout">
                            Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- PAGE CONTENT -->
    <div class="container-fluid main-container">
        <div class="content-card p-4">
            @RenderBody()
        </div>
    </div>

    <!-- MODAL SECTION (IMPORTANT) -->
    @RenderSection("Modals", required: false)

    <!-- FOOTER -->
    <footer class="text-center text-muted small pb-4 mt-4">
        © 2026 Th_Dpt | Enterprise Management System
    </footer>

    <!-- Bootstrap JS (ONLY ONCE) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
