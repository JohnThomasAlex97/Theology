@* @model YourProjectNamespace.Models.LoginViewModel *@
@{
    ViewData["Title"] = "Login";
    Layout = null;   // Remove layout for full screen login
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            height: 100vh;
            background: linear-gradient(rgba(0, 60, 20, 0.6), rgba(0, 40, 10, 0.7)), url('https://images.unsplash.com/photo-1501785888041-af3ef285b470');
            background-size: cover;
            background-position: center;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-box {
            width: 400px;
            padding: 40px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(15px);
            box-shadow: 0 20px 40px rgba(0, 80, 0, 0.4);
            color: #fff;
        }

            .login-box h2 {
                text-align: center;
                margin-bottom: 30px;
                font-weight: 600;
            }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            font-size: 14px;
        }

        input {
            width: 100%;
            padding: 12px;
            margin-top: 6px;
            border-radius: 10px;
            border: none;
            outline: none;
            background: rgba(255,255,255,0.85);
        }

            input:focus {
                border: 2px solid #2ecc71;
            }

        .btn-login {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, #1e8449, #2ecc71);
            color: white;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s;
        }

            .btn-login:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(0, 120, 0, 0.5);
            }

        .validation-summary-errors {
            color: #ffdddd;
            font-size: 13px;
            margin-bottom: 15px;
        }

        .footer {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            opacity: 0.8;
        }
    </style>
</head>

<body>
    <div class="login-box">
        <h2>🌿 Welcome Back</h2>

        <form asp-controller="Dashboard" asp-action="Dashboard">
            <div asp-validation-summary="ModelOnly"></div>

            <div class="form-group">
                <label>Email</label>
                <input type="text" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" />
            </div>

            <div class="form-group">
                <button type="submit" class="btn-login">Login</button>
            </div>
        </form>

        <div class="footer">
            Class Management System © 2026
        </div>
    </div>
</body>
</html>
